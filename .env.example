# Copy this file to .env.local and paste your key.
OPENAI_API_KEY=sk-your-key-here

# Set to true if you want the app to generate real moodboard images.
# Leave false for cheaper testing. You will still get recommendations and visual prompts.
GENERATE_MOODBOARD_IMAGES=false

# Optional: switch models if needed.
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
